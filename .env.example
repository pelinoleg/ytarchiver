# Copy to .env and adjust

# Backend
DATA_DIR=./data
DOWNLOAD_DIR=./downloads
DB_PATH=./data/ytarchiver.db
LOG_LEVEL=INFO

# Sync scheduler
SYNC_INTERVAL_MINUTES=240          # how often to scan all channels (with jitter)
SYNC_JITTER_MINUTES=60             # +/- random jitter to avoid YT pattern detection
MAX_VIDEOS_PER_CHANNEL_SCAN=50     # cap entries fetched per channel scan

# Default download quality (per-video can override)
DEFAULT_QUALITY=480                # 1080 | 720 | 480 | 360 | best  (start small while testing)

# Retention (0 = keep forever)
DEFAULT_RETENTION_DAYS=0

# SponsorBlock
SPONSORBLOCK_API=https://sponsor.ajay.app
SPONSORBLOCK_REFRESH_DAYS=7        # re-fetch segments for videos newer than this
